# 数据库配置 - 使用MySQL作为持久化数据库
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cloud_prosperity
DB_USER=root
DB_PASSWORD=123456

# 强制同步数据库(首次设置为true创建表，之后改为false保持数据)
DB_FORCE_SYNC=false

# JWT配置
JWT_SECRET=cloud-prosperity-jwt-secret-key-2024
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

# 服务器配置
PORT=3001
NODE_ENV=development

# CORS配置
CORS_ORIGIN=http://localhost:5173

# 日志配置
LOG_LEVEL=info